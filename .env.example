# Copy to .env.local and fill in. Both are optional: with no key, the app runs on a
# free OpenStreetMap (MapLibre) basemap. With a key, it switches to a Google base map
# and shows live Google photos/ratings/reviews on each place.

# Google Maps Platform browser key — enable "Maps JavaScript API" + "Places API (New)",
# and restrict the key by HTTP referrer to your Pages domain (and localhost for dev).
VITE_GOOGLE_MAPS_API_KEY=

# Optional: a cloud Map ID for custom Google styling. AdvancedMarkers also work with
# the built-in "DEMO_MAP_ID" if you leave this blank.
VITE_GOOGLE_MAP_ID=
